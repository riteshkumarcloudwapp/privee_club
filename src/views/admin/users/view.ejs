<div class="container-fluid mt-4">

  <div class="row">

    <!-- LEFT COLUMN : PROFILE SUMMARY -->
    <div class="col-md-4">
      <div class="card card-primary card-outline text-center">

        <div class="card-body">

          <!-- Profile Image -->
          <img class="img-fluid rounded-circle mb-3 border"
               src="/<%= user.best_pic %>"
               alt="Profile Image"
               style="width:140px; height:140px; object-fit:cover;">

          <h4 class="mb-1">
            <%= user.first_name %> <%= user.last_name %>
          </h4>

          <p class="text-muted mb-2">
            <%= user.gender %> | <%= user.city %>
          </p>

          <% if(user.is_verified === true) { %>
            
            <span class="badge bg-success px-3 py-2">Approved</span>
          <% } else { %>
            <span class="badge bg-warning px-3 py-2">Pending</span>
          <% } %>

          <hr>

          <div class="text-start">
            <p><strong>Email:</strong> <br><%= user.email %></p>
            <p><strong>Mobile:</strong> <br><%= user.mobile_number %></p>
            <p><strong>Nationality:</strong> <br><%= user.nationality %></p>
          </div>

        </div>
      </div>
    </div>

    <!-- RIGHT COLUMN : PROFILE DETAILS -->
    <div class="col-md-8">
      <div class="card">

        <div class="card-header bg-light">
          <h5 class="mb-0">Profile Information</h5>
        </div>

        <div class="card-body">

          <div class="row mb-3">
            <div class="col-md-6">
              <strong>Date of Birth</strong>
              <p class="text-muted"><%= user.dob %></p>
            </div>

            <div class="col-md-6">
              <strong>Zodiac Sign</strong>
              <p class="text-muted"><%= user.zodiac_sign %></p>
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <strong>Height</strong>
              <p class="text-muted"><%= user.height %> cm</p>
            </div>

            <div class="col-md-6">
              <strong>Weight</strong>
              <p class="text-muted"><%= user.weight %> kg</p>
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <strong>Body Type</strong>
              <p class="text-muted"><%= user.body_type %></p>
            </div>

            <div class="col-md-6">
              <strong>Sexual Orientation</strong>
              <p class="text-muted"><%= user.sexual_orientation %></p>
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <strong>Hair Color</strong>
              <p class="text-muted"><%= user.hair_color %></p>
            </div>

            <div class="col-md-6">
              <strong>Eye Color</strong>
              <p class="text-muted"><%= user.eye_color %></p>
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <strong>Region</strong>
              <p class="text-muted"><%= user.region %></p>
            </div>

            <div class="col-md-6">
              <strong>City</strong>
              <p class="text-muted"><%= user.city %></p>
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>

</div>